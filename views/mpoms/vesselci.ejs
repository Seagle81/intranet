<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>모선코드 등록</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary: #4f7cff;
      --primary-grad: linear-gradient(135deg, #4f7cff, #9b59b6);
      --danger: #ef4444;
      --success: #10b981;
      --bg: #f0f2f5;
      --card: #fff;
      --border: #e5e7eb;
      --text: #1a1f36;
      --muted: #6b7280;
      --header-h: 56px;
      --toolbar-h: 52px;
    }

    body {
      font-family: 'Segoe UI', 'Malgun Gothic', sans-serif;
      background: var(--bg); color: var(--text);
      min-height: 100vh;
      padding-bottom: 48px;
    }

    /* ── 헤더 ── */
    .app-header {
      position: sticky; top: 0; z-index: 200;
      background: linear-gradient(135deg, #1a1f36, #2d3561);
      height: var(--header-h);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 20px;
      box-shadow: 0 2px 12px rgba(0,0,0,.3);
    }

    .app-header .title {
      color: #fff; font-size: 15px; font-weight: 700;
      display: flex; align-items: center; gap: 10px;
    }

    .app-header .title .sub {
      font-size: 12px; opacity: .5; font-weight: 400;
    }

    .app-header .right {
      display: flex; align-items: center; gap: 12px;
    }

    .auth-badge {
      font-size: 11px; padding: 2px 8px; border-radius: 20px;
      font-weight: 600;
    }
    .auth-1 { background: #d1fae5; color: #065f46; }
    .auth-2 { background: #dbeafe; color: #1e40af; }
    .auth-3 { background: #fee2e2; color: #991b1b; }

    .user-name { font-size: 13px; color: rgba(255,255,255,.7); }

    .header-link {
      font-size: 12px; color: rgba(255,255,255,.6);
      text-decoration: none; padding: 4px 10px;
      border: 1px solid rgba(255,255,255,.2); border-radius: 6px;
      transition: all .2s;
    }
    .header-link:hover { background: rgba(255,255,255,.1); color: #fff; }

    /* ── 툴바 ── */
    .toolbar {
      position: sticky; top: var(--header-h); z-index: 190;
      background: var(--card);
      border-bottom: 1px solid var(--border);
      padding: 8px 16px;
      display: flex; align-items: center; gap: 6px;
      flex-wrap: wrap;
      box-shadow: 0 1px 4px rgba(0,0,0,.06);
    }

    .toolbar .sep {
      width: 1px; height: 24px; background: var(--border); margin: 0 2px;
    }

    .tb-btn {
      height: 36px; padding: 0 16px;
      border-radius: 8px; border: 1.5px solid var(--border);
      background: var(--card); color: var(--text);
      font-size: 13px; font-weight: 600; font-family: inherit;
      cursor: pointer; white-space: nowrap;
      transition: all .15s;
      display: flex; align-items: center; gap: 5px;
    }
    .tb-btn:hover { background: #f3f4f6; border-color: #d1d5db; }
    .tb-btn:disabled { opacity: .45; cursor: not-allowed; }

    .tb-btn.primary {
      background: var(--primary-grad); color: #fff;
      border-color: transparent;
    }
    .tb-btn.primary:hover { opacity: .88; }

    .tb-btn.success {
      background: var(--success); color: #fff;
      border-color: transparent;
    }
    .tb-btn.success:hover { opacity: .88; }

    .tb-btn.danger {
      background: var(--danger); color: #fff;
      border-color: transparent;
    }
    .tb-btn.danger:hover { opacity: .88; }

    /* ── 본문 ── */
    .page-body { padding: 16px; display: flex; flex-direction: column; gap: 16px; }

    /* ── 카드 ── */
    .card {
      background: var(--card); border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,.06);
      overflow: hidden;
    }

    .card-header {
      padding: 10px 18px;
      background: #f8f9fc;
      border-bottom: 1px solid var(--border);
      font-size: 12px; font-weight: 700;
      color: var(--muted); text-transform: uppercase; letter-spacing: .5px;
    }

    /* ── 폼 그리드 ── */
    .form-grid {
      padding: 16px 18px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px 20px;
    }

    @media (max-width: 860px) {
      .form-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 540px) {
      .form-grid { grid-template-columns: 1fr; gap: 10px 0; }
    }

    .fg { display: flex; flex-direction: column; gap: 5px; }
    .fg.span-2 { grid-column: span 2; }
    .fg.span-3 { grid-column: 1 / -1; }

    @media (max-width: 860px) {
      .fg.span-3 { grid-column: 1 / -1; }
      .fg.span-2 { grid-column: 1 / -1; }
    }

    .fg label {
      font-size: 11px; font-weight: 600;
      color: var(--muted); white-space: nowrap;
    }

    .fg label .req { color: var(--danger); margin-left: 2px; }

    .fg .inp-wrap { display: flex; align-items: center; gap: 6px; }

    .inp {
      width: 100%; height: 36px;
      padding: 0 10px;
      border: 1.5px solid var(--border);
      border-radius: 7px;
      font-size: 13px; font-family: inherit;
      background: #fafafa; color: var(--text);
      outline: none; transition: border-color .2s, background .2s;
    }
    .inp:focus { border-color: var(--primary); background: #fff; }
    .inp.key-field  { text-transform: uppercase; font-weight: 700; letter-spacing: 1px; }
    .inp.ro-field   { background: #f3f4f6; color: var(--muted); }
    .inp.ro-field:focus { border-color: var(--border); background: #f3f4f6; }
    .inp.num-field  { text-align: right; }
    .inp.error      { border-color: var(--danger); background: #fff5f5; }

    .inp-code { width: 70px; flex-shrink: 0; }
    .inp-code-sm { width: 56px; flex-shrink: 0; }
    .inp-auto { flex: 1; min-width: 0; }
    .inp-range { width: 52px; flex-shrink: 0; text-align: center; }

    .range-sep { color: var(--muted); font-size: 13px; flex-shrink: 0; }

    .sel {
      height: 36px; padding: 0 10px;
      border: 1.5px solid var(--border); border-radius: 7px;
      font-size: 13px; font-family: inherit;
      background: #fafafa; color: var(--text);
      outline: none; cursor: pointer;
      transition: border-color .2s;
    }
    .sel:focus { border-color: var(--primary); background: #fff; }

    .btn-lookup {
      height: 36px; padding: 0 10px;
      border: 1.5px solid var(--border); border-radius: 7px;
      background: var(--card); color: var(--text);
      font-size: 12px; font-weight: 600; font-family: inherit;
      cursor: pointer; white-space: nowrap; flex-shrink: 0;
      transition: all .15s;
    }
    .btn-lookup:hover { background: #f3f4f6; }

    .card-divider { height: 1px; background: var(--border); margin: 2px 18px 0; }

    /* ── 목록 테이블 ── */
    .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }

    .vessel-table { width: 100%; border-collapse: collapse; font-size: 13px; white-space: nowrap; }

    .vessel-table thead tr { background: #f8f9fc; }
    .vessel-table th {
      padding: 10px 14px; text-align: left;
      font-size: 11px; font-weight: 700;
      color: var(--muted); text-transform: uppercase; letter-spacing: .4px;
      border-bottom: 2px solid var(--border);
      cursor: pointer; user-select: none;
      transition: background .15s;
    }
    .vessel-table th:hover { background: #f0f2f5; }
    .vessel-table th.sorted-asc::after  { content: ' ▲'; font-size: 9px; }
    .vessel-table th.sorted-desc::after { content: ' ▼'; font-size: 9px; }

    .vessel-table tbody tr { border-bottom: 1px solid #f3f4f6; transition: background .12s; cursor: pointer; }
    .vessel-table tbody tr:hover td { background: #f0f4ff; }
    .vessel-table tbody tr.selected td { background: #4f7cff; color: #fff; }
    .vessel-table td { padding: 10px 14px; }
    .vessel-table td.center { text-align: center; }
    .vessel-table td.right  { text-align: right; }
    .vessel-table .empty-row td {
      text-align: center; padding: 40px;
      color: var(--muted); font-size: 13px;
    }

    /* ── 상태바 ── */
    .status-bar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 150;
      background: var(--card);
      border-top: 1px solid var(--border);
      padding: 8px 16px;
      display: flex; align-items: center; gap: 12px;
      font-size: 12px;
      box-shadow: 0 -2px 8px rgba(0,0,0,.06);
    }
    .status-msg { flex: 1; color: var(--danger); font-weight: 600; }
    .status-side { color: var(--muted); padding-left: 12px; border-left: 1px solid var(--border); }

    /* ── 모달 ── */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.45); z-index: 500;
      align-items: center; justify-content: center;
      padding: 16px;
    }
    .modal-overlay.show { display: flex; }

    .modal {
      background: var(--card); border-radius: 14px;
      width: 100%; max-width: 360px;
      box-shadow: 0 20px 60px rgba(0,0,0,.3);
      overflow: hidden;
    }

    .modal-header {
      background: linear-gradient(135deg, #1a1f36, #2d3561);
      color: #fff; padding: 14px 20px;
      font-size: 14px; font-weight: 700;
    }

    .modal-body {
      padding: 20px; font-size: 14px; line-height: 1.6;
      color: var(--text);
    }

    .modal-footer {
      padding: 12px 20px; border-top: 1px solid var(--border);
      display: flex; justify-content: flex-end; gap: 8px;
    }

    .modal-footer button {
      height: 36px; padding: 0 20px;
      border-radius: 8px; border: 1.5px solid var(--border);
      font-size: 13px; font-weight: 600; font-family: inherit;
      cursor: pointer; transition: all .15s;
    }

    .modal-footer .btn-primary {
      background: var(--primary-grad); color: #fff;
      border-color: transparent;
    }
    .modal-footer .btn-primary:hover { opacity: .88; }
    .modal-footer button:not(.btn-primary):hover { background: #f3f4f6; }

    /* ── 반응형 헤더 축약 ── */
    @media (max-width: 540px) {
      .user-name { display: none; }
      .app-header { padding: 0 12px; }
      .toolbar { padding: 8px 10px; gap: 4px; }
      .tb-btn { height: 34px; padding: 0 12px; font-size: 12px; }
      .page-body { padding: 10px; gap: 10px; }
    }
  </style>
</head>
<body>

<!-- ── 헤더 ── -->
<header class="app-header">
  <div class="title">
    모선코드 등록
    <span class="sub">MPOMS 코드관리</span>
  </div>
  <div class="right">
    <% const authLabels = ['', '조회', '등록/수정', '삭제포함']; %>
    <span class="auth-badge auth-<%= authLevel %>"><%= authLabels[authLevel] %></span>
    <span class="user-name"><%= user.name %> (<%= user.empNo %>)</span>
    <a class="header-link" href="/main">메인</a>
    <a class="header-link" href="/logout">로그아웃</a>
  </div>
</header>

<!-- ── 툴바 ── -->
<div class="toolbar">
  <button class="tb-btn" id="btn-exit">← 메인</button>
  <div class="sep"></div>
  <button class="tb-btn primary" id="btn-search">조회</button>
  <% if (authLevel >= 2) { %>
  <button class="tb-btn success" id="btn-add">+ 추가</button>
  <button class="tb-btn success" id="btn-save">저장</button>
  <% } %>
  <% if (authLevel >= 3) { %>
  <button class="tb-btn danger" id="btn-delete">삭제</button>
  <% } %>
  <div class="sep"></div>
  <button class="tb-btn" id="btn-clear">초기화</button>
</div>

<!-- ── 본문 ── -->
<div class="page-body">

  <!-- 기본 정보 -->
  <div class="card">
    <div class="card-header">기본 정보</div>
    <div class="form-grid">

      <div class="fg">
        <label>모선코드<span class="req">*</span></label>
        <div class="inp-wrap">
          <input type="text" id="vessel_code" maxlength="4" class="inp inp-code key-field">
          <button class="btn-lookup" id="btn-code-help">코드검색</button>
        </div>
      </div>

      <div class="fg">
        <label>호출부호<span class="req">*</span></label>
        <input type="text" id="call_sign" maxlength="20" class="inp">
      </div>

      <div class="fg">
        <label>CNTR / BULK 구분</label>
        <select id="cntr_bulk_type" class="sel">
          <option value="">선택</option>
          <option value="C">CNTR</option>
          <option value="B">BULK</option>
          <option value="G">일반</option>
        </select>
      </div>

      <div class="fg span-3">
        <label>모선명 (영문)<span class="req">*</span></label>
        <input type="text" id="vessel_name_eng" maxlength="100" class="inp">
      </div>

      <div class="fg">
        <label>LINE 코드</label>
        <div class="inp-wrap">
          <input type="text" id="line_code" maxlength="3" class="inp inp-code-sm key-field">
          <button class="btn-lookup" id="btn-line-help">검색</button>
          <input type="text" id="line_name" maxlength="30" class="inp inp-auto ro-field" readonly>
        </div>
      </div>

      <div class="fg">
        <label>국가 코드</label>
        <div class="inp-wrap">
          <input type="text" id="country_code" maxlength="2" class="inp inp-code-sm key-field">
          <button class="btn-lookup" id="btn-country-help">검색</button>
          <input type="text" id="country_name" maxlength="30" class="inp inp-auto ro-field" readonly>
        </div>
      </div>

      <div class="fg">
        <label>선박 유형</label>
        <input type="text" id="ship_type" maxlength="20" class="inp">
      </div>

      <div class="fg span-3">
        <label>모선명 (한글)</label>
        <input type="text" id="vessel_name_kor" maxlength="100" class="inp">
      </div>

    </div>
  </div>

  <!-- 제원 정보 -->
  <div class="card">
    <div class="card-header">제원 정보</div>
    <div class="form-grid">

      <div class="fg">
        <label>총 톤수</label>
        <input type="text" id="gross_tonnage" maxlength="15" class="inp num-field">
      </div>
      <div class="fg">
        <label>재화중량톤 (DWT)</label>
        <input type="text" id="dwt" maxlength="15" class="inp num-field">
      </div>
      <div class="fg">
        <label>전장 (LOA)</label>
        <input type="text" id="loa" maxlength="10" class="inp num-field">
      </div>
      <div class="fg">
        <label>전폭 (BEAM)</label>
        <input type="text" id="beam" maxlength="10" class="inp num-field">
      </div>
      <div class="fg">
        <label>창구 개수</label>
        <input type="text" id="hatch_count" maxlength="10" class="inp num-field">
      </div>
      <div class="fg">
        <label>일공 마력수</label>
        <input type="text" id="horsepower" maxlength="10" class="inp num-field">
      </div>
      <div class="fg">
        <label>흘수 기준</label>
        <input type="text" id="draft" maxlength="8" class="inp num-field">
      </div>

    </div>
  </div>

  <!-- 적재 정보 -->
  <div class="card">
    <div class="card-header">적재 정보</div>
    <div class="form-grid">

      <div class="fg">
        <label>화물 MAX HATCH</label>
        <input type="text" id="max_hatch" maxlength="5" class="inp num-field">
      </div>
      <div class="fg">
        <label>화물 MAX BAY</label>
        <input type="text" id="bay_to" maxlength="5" class="inp num-field">
      </div>
      <div class="fg">
        <label>CRANE 수</label>
        <input type="text" id="crane_count" maxlength="5" class="inp">
      </div>

      <div class="fg">
        <label>화물 ROW (FROM ~ TO)</label>
        <div class="inp-wrap">
          <input type="text" id="row_from" maxlength="3" class="inp inp-range num-field">
          <span class="range-sep">~</span>
          <input type="text" id="row_to" maxlength="3" class="inp inp-range num-field">
        </div>
      </div>
      <div class="fg">
        <label>화물 ROW DECK (FROM ~ TO)</label>
        <div class="inp-wrap">
          <input type="text" id="rowd_from" maxlength="3" class="inp inp-range num-field">
          <span class="range-sep">~</span>
          <input type="text" id="rowd_to" maxlength="3" class="inp inp-range num-field">
        </div>
      </div>
      <div class="fg">
        <label>TIER HOLD (FROM ~ TO)</label>
        <div class="inp-wrap">
          <input type="text" id="tierh_from" maxlength="3" class="inp inp-range num-field">
          <span class="range-sep">~</span>
          <input type="text" id="tierh_to" maxlength="3" class="inp inp-range num-field">
        </div>
      </div>
      <div class="fg">
        <label>TIER DECK (FROM ~ TO)</label>
        <div class="inp-wrap">
          <input type="text" id="tierd_from" maxlength="3" class="inp inp-range num-field">
          <span class="range-sep">~</span>
          <input type="text" id="tierd_to" maxlength="3" class="inp inp-range num-field">
        </div>
      </div>

    </div>
  </div>

  <!-- 비고 -->
  <div class="card">
    <div class="card-header">비고 (REMARK)</div>
    <div class="form-grid">
      <div class="fg span-3">
        <label>REMARK 1</label>
        <input type="text" id="remark1" maxlength="100" class="inp">
      </div>
      <div class="fg span-3">
        <label>REMARK 2</label>
        <input type="text" id="remark2" maxlength="100" class="inp">
      </div>
      <div class="fg span-3">
        <label>REMARK 3</label>
        <input type="text" id="remark3" maxlength="100" class="inp">
      </div>
    </div>
  </div>

  <!-- 목록 -->
  <div class="card">
    <div class="card-header">모선코드 목록</div>
    <div class="table-wrap">
      <table class="vessel-table" id="vessel-grid">
        <thead>
          <tr>
            <th data-col="vessel_code"     style="width:90px">모선코드</th>
            <th data-col="vessel_name_eng">모선명 (영문)</th>
            <th data-col="country_code"    style="width:80px">국가코드</th>
            <th data-col="line_code"       style="width:80px">LINE</th>
            <th data-col="call_sign"       style="width:110px">호출부호</th>
            <th data-col="gross_tonnage"   style="width:110px">총 톤수</th>
          </tr>
        </thead>
        <tbody id="grid-body">
          <tr class="empty-row">
            <td colspan="6">조회 버튼을 눌러 목록을 불러오세요.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ── 상태바 ── -->
<div class="status-bar">
  <span class="status-msg" id="status-msg">조회할 자료를 입력하십시오.</span>
  <span class="status-side">prc_vesselci</span>
  <span class="status-side" id="status-date"></span>
</div>

<!-- ── 확인 모달 ── -->
<div class="modal-overlay" id="modal-confirm">
  <div class="modal">
    <div class="modal-header">확인</div>
    <div class="modal-body" id="modal-confirm-msg"></div>
    <div class="modal-footer">
      <button id="modal-yes" class="btn-primary">예</button>
      <button id="modal-no">아니오</button>
    </div>
  </div>
</div>

<script>
const AUTH_LEVEL   = <%= authLevel %>;
const CURRENT_USER = '<%= user.empNo %>';
</script>
<script src="/mpoms/vesselci/app.js"></script>
</body>
</html>
