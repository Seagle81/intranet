<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>프로그램 접근권한 관리</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh; background: #f0f2f5;
      font-family: 'Segoe UI', 'Malgun Gothic', sans-serif; color: #1a1f36;
    }

    header {
      background: linear-gradient(135deg, #1a1f36, #2d3561); color: #fff;
      padding: 0 32px; height: 60px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 2px 12px rgba(0,0,0,0.3); position: sticky; top: 0; z-index: 100;
    }

    .header-left { display: flex; align-items: center; gap: 12px; font-size: 16px; font-weight: 600; }
    .header-right { display: flex; align-items: center; gap: 16px; }
    .user-info { font-size: 13px; color: rgba(255,255,255,0.7); }

    .btn-logout {
      padding: 7px 16px; background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2); border-radius: 8px;
      color: #fff; font-size: 13px; text-decoration: none; transition: background 0.2s;
    }
    .btn-logout:hover { background: rgba(255,255,255,0.2); }

    .container { max-width: 1000px; margin: 0 auto; padding: 32px 16px; }

    .page-header { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
    .page-title { font-size: 22px; font-weight: 700; }
    .btn-back {
      padding: 7px 16px; background: #fff; border: 1.5px solid #e5e7eb;
      border-radius: 8px; color: #374151; font-size: 13px; text-decoration: none;
      transition: background 0.2s;
    }
    .btn-back:hover { background: #f3f4f6; }

    .card {
      background: #fff; border-radius: 14px; padding: 28px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.07); margin-bottom: 24px;
    }

    .card-title {
      font-size: 15px; font-weight: 600; margin-bottom: 20px;
      padding-bottom: 12px; border-bottom: 1px solid #eef0f5;
    }

    .form-row { display: grid; gap: 10px; align-items: end; }
    .cols-2 { grid-template-columns: 1fr 1fr auto; }
    .cols-4 { grid-template-columns: 1.3fr 1.3fr 1fr auto; }

    .form-group label {
      display: block; font-size: 12px; font-weight: 600;
      color: #6b7280; margin-bottom: 6px;
    }

    .form-group select, .form-group input {
      width: 100%; padding: 9px 14px; border: 1.5px solid #e5e7eb;
      border-radius: 8px; font-size: 14px; outline: none;
      transition: border-color 0.2s; background: #fafafa;
    }
    .form-group select:focus, .form-group input:focus {
      border-color: #4f7cff; background: #fff;
    }

    .alert { border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-top: 12px; display: none; }
    .alert.show { display: block; }
    .alert-success { background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; }
    .alert-error   { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }

    .btn-primary {
      padding: 9px 20px; background: linear-gradient(135deg, #4f7cff, #9b59b6);
      border: none; border-radius: 8px; color: #fff;
      font-size: 14px; font-weight: 600; cursor: pointer; transition: opacity 0.2s;
      white-space: nowrap;
    }
    .btn-primary:hover { opacity: 0.88; }

    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    thead tr { background: #f8f9fc; border-bottom: 2px solid #e5e7eb; }
    thead th {
      padding: 12px 16px; text-align: left;
      font-size: 12px; font-weight: 600; color: #6b7280;
      text-transform: uppercase; letter-spacing: 0.5px;
    }
    tbody tr { border-bottom: 1px solid #f3f4f6; transition: background 0.15s; }
    tbody tr:hover { background: #f8f9fc; }
    tbody td { padding: 13px 16px; color: #374151; }

    .prog-row { cursor: pointer; }
    .prog-row.selected { background: #ede9fe !important; }

    .count-badge {
      display: inline-block; padding: 1px 8px; border-radius: 20px;
      font-size: 11px; font-weight: 600;
      background: #dbeafe; color: #1d4ed8;
    }

    .level-badge {
      display: inline-block; padding: 2px 10px; border-radius: 20px;
      font-size: 11px; font-weight: 600;
    }
    .level-1 { background: #dbeafe; color: #1d4ed8; }
    .level-2 { background: #dcfce7; color: #166534; }
    .level-3 { background: #fde8e8; color: #991b1b; }

    .btn-sm {
      padding: 4px 12px; border-radius: 6px; font-size: 12px;
      cursor: pointer; border: 1.5px solid transparent; transition: all 0.2s;
    }
    .btn-delete { background: #fff; border-color: #fca5a5; color: #dc2626; }
    .btn-delete:hover { background: #fef2f2; }

    .empty-state { text-align: center; padding: 40px; color: #9ca3af; font-size: 14px; }

    .divider { border: none; border-top: 1px solid #eef0f5; margin: 20px 0; }

    .auth-list-title {
      font-size: 13px; font-weight: 600; color: #6b7280;
      margin-bottom: 12px;
    }
  </style>
</head>
<body>

<header>
  <div class="header-left">인트라넷 <span style="font-size:12px;opacity:0.6;">/ 접근권한 관리</span></div>
  <div class="header-right">
    <span class="user-info"><%= user.name %> (<%= user.empNo %>)</span>
    <a class="btn-logout" href="/logout">로그아웃</a>
  </div>
</header>

<div class="container">
  <div class="page-header">
    <a class="btn-back" href="/admin">← 관리자 홈</a>
    <div class="page-title">프로그램 접근권한 관리</div>
  </div>

  <!-- 프로그램 등록 -->
  <div class="card">
    <div class="card-title">프로그램 등록</div>
    <div class="form-row cols-2">
      <div class="form-group">
        <label>프로그램 ID</label>
        <input type="text" id="newProgId" placeholder="예) prc_vesselci">
      </div>
      <div class="form-group">
        <label>프로그램명</label>
        <input type="text" id="newProgName" placeholder="예) 모선코드 관리">
      </div>
      <button class="btn-primary" onclick="addProg()">등록</button>
    </div>
    <div class="alert alert-success" id="progSuccess"></div>
    <div class="alert alert-error"   id="progError"></div>
  </div>

  <!-- 프로그램 목록 -->
  <div class="card">
    <div class="card-title">프로그램 목록</div>
    <table>
      <thead>
        <tr>
          <th>프로그램 ID</th>
          <th>프로그램명</th>
          <th>권한 인원</th>
          <th>관리</th>
        </tr>
      </thead>
      <tbody id="progTableBody">
        <tr><td colspan="4"><div class="empty-state">등록된 프로그램이 없습니다.</div></td></tr>
      </tbody>
    </table>
  </div>

  <!-- 권한 부여 / 권한 목록 -->
  <div class="card">
    <div class="card-title">권한 부여</div>
    <div class="form-row cols-4">
      <div class="form-group">
        <label>프로그램</label>
        <select id="selProgId" onchange="onProgChange()">
          <option value="">프로그램 선택</option>
        </select>
      </div>
      <div class="form-group">
        <label>사용자</label>
        <select id="empNo">
          <option value="">사용자 선택</option>
        </select>
      </div>
      <div class="form-group">
        <label>권한 레벨</label>
        <select id="authLevel">
          <option value="1">1 - 조회</option>
          <option value="2">2 - 등록/수정</option>
          <option value="3">3 - 삭제 포함</option>
        </select>
      </div>
      <button class="btn-primary" onclick="grantAuth()">권한 부여</button>
    </div>
    <div class="alert alert-success" id="grantSuccess"></div>
    <div class="alert alert-error"   id="grantError"></div>

    <hr class="divider">

    <div class="auth-list-title" id="authListTitle">프로그램을 선택하면 권한 목록이 표시됩니다.</div>
    <table>
      <thead>
        <tr>
          <th>사번</th><th>이름</th><th>권한 레벨</th><th>등록일시</th><th>관리</th>
        </tr>
      </thead>
      <tbody id="authTableBody">
        <tr><td colspan="5"><div class="empty-state">프로그램을 선택하세요.</div></td></tr>
      </tbody>
    </table>
  </div>

</div>

<script>
  var currentProgId = '';

  // ── 사용자 목록 로드 ─────────────────────────────────────────────────────────
  async function loadUsers() {
    var res  = await fetch('/api/prog_auth/users/all');
    var data = await res.json();
    if (!data.success) return;
    var sel = document.getElementById('empNo');
    data.data.forEach(function(u) {
      var opt = document.createElement('option');
      opt.value = u.empNo;
      opt.textContent = u.name + ' (' + u.empNo + ')';
      sel.appendChild(opt);
    });
  }

  // ── 프로그램 목록 로드 (테이블 + 드롭다운 동시 갱신) ────────────────────────
  async function loadProgs() {
    var res  = await fetch('/api/prog_auth/progs');
    var data = await res.json();
    var tbody = document.getElementById('progTableBody');
    var sel   = document.getElementById('selProgId');

    // 드롭다운 갱신 (현재 선택값 유지)
    var prevVal = sel.value;
    sel.innerHTML = '<option value="">프로그램 선택</option>';

    if (!data.success || !data.data.length) {
      tbody.innerHTML = '<tr><td colspan="4"><div class="empty-state">등록된 프로그램이 없습니다.</div></td></tr>';
      return;
    }

    data.data.forEach(function(p) {
      var opt = document.createElement('option');
      opt.value = p.prog_id;
      opt.textContent = p.prog_id + '  —  ' + p.prog_name;
      sel.appendChild(opt);
    });

    // 이전 선택값 복원
    if (prevVal) sel.value = prevVal;

    // 프로그램 테이블 갱신
    tbody.innerHTML = data.data.map(function(p) {
      var isSelected = p.prog_id === currentProgId;
      return '<tr class="prog-row' + (isSelected ? ' selected' : '') + '" onclick="selectProg(\'' + esc(p.prog_id) + '\')">' +
        '<td><strong>' + esc(p.prog_id) + '</strong></td>' +
        '<td>' + esc(p.prog_name) + '</td>' +
        '<td><span class="count-badge">' + (p.auth_count || 0) + '명</span></td>' +
        '<td onclick="event.stopPropagation()">' +
          '<button class="btn-sm btn-delete" onclick="deleteProg(\'' + esc(p.prog_id) + '\',\'' + esc(p.prog_name) + '\')">삭제</button>' +
        '</td>' +
      '</tr>';
    }).join('');
  }

  // ── 프로그램 등록 ───────────────────────────────────────────────────────────
  async function addProg() {
    var progId   = document.getElementById('newProgId').value.trim();
    var progName = document.getElementById('newProgName').value.trim();
    var succEl   = document.getElementById('progSuccess');
    var errEl    = document.getElementById('progError');
    succEl.classList.remove('show');
    errEl.classList.remove('show');

    if (!progId || !progName) {
      errEl.textContent = '프로그램 ID와 프로그램명을 모두 입력하세요.';
      errEl.classList.add('show');
      return;
    }

    var res  = await fetch('/api/prog_auth/progs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ progId: progId, progName: progName })
    });
    var data = await res.json();

    if (data.success) {
      succEl.textContent = data.message;
      succEl.classList.add('show');
      document.getElementById('newProgId').value   = '';
      document.getElementById('newProgName').value = '';
      loadProgs();
    } else {
      errEl.textContent = data.message;
      errEl.classList.add('show');
    }
  }

  // ── 프로그램 삭제 ───────────────────────────────────────────────────────────
  async function deleteProg(progId, progName) {
    if (!confirm('[' + progId + '] ' + progName + '\n이 프로그램과 모든 권한을 삭제하시겠습니까?')) return;
    var res  = await fetch('/api/prog_auth/progs/' + encodeURIComponent(progId), { method: 'DELETE' });
    var data = await res.json();
    if (data.success) {
      if (currentProgId === progId) {
        currentProgId = '';
        document.getElementById('selProgId').value = '';
        document.getElementById('authListTitle').textContent = '프로그램을 선택하면 권한 목록이 표시됩니다.';
        document.getElementById('authTableBody').innerHTML =
          '<tr><td colspan="5"><div class="empty-state">프로그램을 선택하세요.</div></td></tr>';
      }
      loadProgs();
    } else {
      alert(data.message);
    }
  }

  // ── 드롭다운 변경 시 ─────────────────────────────────────────────────────────
  function onProgChange() {
    var progId = document.getElementById('selProgId').value;
    if (!progId) return;
    selectProg(progId);
  }

  // ── 프로그램 선택 (테이블 행 클릭 또는 드롭다운 선택) ────────────────────────
  function selectProg(progId) {
    currentProgId = progId;

    // 드롭다운 동기화
    document.getElementById('selProgId').value = progId;

    // 테이블 행 강조
    document.querySelectorAll('.prog-row').forEach(function(tr) {
      var strong = tr.querySelector('td strong');
      tr.classList.toggle('selected', strong && strong.textContent === progId);
    });

    document.getElementById('grantSuccess').classList.remove('show');
    document.getElementById('grantError').classList.remove('show');
    loadAuth();
  }

  // ── 권한 목록 로드 ───────────────────────────────────────────────────────────
  async function loadAuth() {
    if (!currentProgId) return;
    var res  = await fetch('/api/prog_auth/' + encodeURIComponent(currentProgId));
    var data = await res.json();
    var tbody = document.getElementById('authTableBody');

    document.getElementById('authListTitle').textContent =
      '[' + currentProgId + '] 권한 목록';

    if (!data.success || !data.data.length) {
      tbody.innerHTML = '<tr><td colspan="5"><div class="empty-state">등록된 권한이 없습니다.</div></td></tr>';
      loadProgs();
      return;
    }

    var levelLabel = { '1': '1 - 조회', '2': '2 - 등록/수정', '3': '3 - 삭제포함' };
    var levelClass = { '1': 'level-1',  '2': 'level-2',      '3': 'level-3' };

    tbody.innerHTML = data.data.map(function(r) {
      return '<tr>' +
        '<td>' + esc(r.emp_no) + '</td>' +
        '<td>' + esc(r.name || '-') + '</td>' +
        '<td><span class="level-badge ' + (levelClass[r.auth_level] || '') + '">' + (levelLabel[r.auth_level] || r.auth_level) + '</span></td>' +
        '<td>' + esc(r.reg_date ? r.reg_date.toString().slice(0,19).replace('T',' ') : '') + '</td>' +
        '<td><button class="btn-sm btn-delete" onclick="deleteAuth(\'' + esc(r.emp_no) + '\')">삭제</button></td>' +
      '</tr>';
    }).join('');

    loadProgs();
  }

  // ── 권한 부여 ────────────────────────────────────────────────────────────────
  async function grantAuth() {
    var progId    = document.getElementById('selProgId').value;
    var empNo     = document.getElementById('empNo').value;
    var authLevel = document.getElementById('authLevel').value;
    var succEl    = document.getElementById('grantSuccess');
    var errEl     = document.getElementById('grantError');
    succEl.classList.remove('show');
    errEl.classList.remove('show');

    if (!progId) {
      errEl.textContent = '프로그램을 선택하세요.';
      errEl.classList.add('show');
      return;
    }
    if (!empNo) {
      errEl.textContent = '사용자를 선택하세요.';
      errEl.classList.add('show');
      return;
    }

    var res  = await fetch('/api/prog_auth', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ progId: progId, empNo: empNo, authLevel: authLevel })
    });
    var data = await res.json();
    if (data.success) {
      succEl.textContent = data.message;
      succEl.classList.add('show');
      loadAuth();
    } else {
      errEl.textContent = data.message;
      errEl.classList.add('show');
    }
  }

  // ── 권한 삭제 ────────────────────────────────────────────────────────────────
  async function deleteAuth(empNo) {
    if (!confirm(empNo + ' 사용자의 권한을 삭제하시겠습니까?')) return;
    var res  = await fetch('/api/prog_auth/' + encodeURIComponent(currentProgId) + '/' + encodeURIComponent(empNo), { method: 'DELETE' });
    var data = await res.json();
    if (data.success) loadAuth();
    else alert(data.message);
  }

  function esc(v) {
    return String(v == null ? '' : v)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }

  loadProgs();
  loadUsers();
</script>
</body>
</html>
