<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>관리자 - 사용자 관리</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh; background: #f0f2f5;
      font-family: 'Segoe UI', 'Malgun Gothic', sans-serif; color: #1a1f36;
    }

    header {
      background: linear-gradient(135deg, #1a1f36, #2d3561); color: #fff;
      padding: 0 32px; height: 60px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 2px 12px rgba(0,0,0,0.3); position: sticky; top: 0; z-index: 100;
    }

    .header-left { display: flex; align-items: center; gap: 12px; font-size: 16px; font-weight: 600; }

    .badge-admin {
      background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.2);
      border-radius: 6px; padding: 2px 10px; font-size: 11px; color: rgba(255,255,255,0.8);
    }

    .header-right { display: flex; align-items: center; gap: 16px; }
    .user-info { font-size: 13px; color: rgba(255,255,255,0.7); }

    .btn-logout {
      padding: 7px 16px; background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: #fff;
      font-size: 13px; cursor: pointer; text-decoration: none; transition: background 0.2s;
    }
    .btn-logout:hover { background: rgba(255,255,255,0.2); }

    .container { max-width: 1100px; margin: 0 auto; padding: 32px 16px; }
    .page-header { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
    .page-title { font-size: 22px; font-weight: 700; }
    .btn-nav {
      padding: 8px 16px; background: #fff; border: 1.5px solid #e5e7eb;
      border-radius: 8px; color: #374151; font-size: 13px; font-weight: 500;
      text-decoration: none; transition: background 0.2s; white-space: nowrap;
    }
    .btn-nav:hover { background: #f3f4f6; }

    .card {
      background: #fff; border-radius: 14px; padding: 28px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.07); margin-bottom: 24px;
    }

    .card-title {
      font-size: 15px; font-weight: 600; margin-bottom: 20px;
      padding-bottom: 12px; border-bottom: 1px solid #eef0f5;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px; margin-bottom: 12px;
    }
    .form-grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr auto;
      gap: 12px; align-items: end;
    }
    @media (max-width: 640px) {
      .form-grid { grid-template-columns: 1fr; }
      .form-grid-2 { grid-template-columns: 1fr; }
    }

    .form-group label {
      display: block; font-size: 12px; font-weight: 600; color: #6b7280;
      margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;
    }

    .form-group input,
    .form-group select {
      width: 100%; padding: 10px 14px; border: 1.5px solid #e5e7eb;
      border-radius: 8px; font-size: 14px; color: #1a1f36;
      transition: border-color 0.2s; outline: none; background: #fafafa;
    }

    .form-group input:focus,
    .form-group select:focus { border-color: #4f7cff; background: #fff; }

    .btn-add {
      padding: 10px 22px; height: 41px;
      background: linear-gradient(135deg, #4f7cff, #9b59b6);
      border: none; border-radius: 8px; color: #fff;
      font-size: 14px; font-weight: 600; cursor: pointer;
      white-space: nowrap; transition: opacity 0.2s;
    }
    .btn-add:hover { opacity: 0.85; }
    .btn-add:disabled { opacity: 0.6; cursor: not-allowed; }

    .alert { display: none; border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-top: 14px; }
    .alert.show { display: block; }
    .alert-success { background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; }
    .alert-error   { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }

    .list-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }

    .search-input {
      padding: 8px 14px; border: 1.5px solid #e5e7eb; border-radius: 8px;
      font-size: 13px; outline: none; width: 220px; transition: border-color 0.2s;
    }
    .search-input:focus { border-color: #4f7cff; }
    .user-count { font-size: 13px; color: #6b7280; }
    .table-wrap { overflow-x: auto; }

    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    thead tr { background: #f8f9fc; border-bottom: 2px solid #e5e7eb; }

    thead th {
      padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 600;
      color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap;
    }

    tbody tr { border-bottom: 1px solid #f3f4f6; transition: background 0.15s; }
    tbody tr:hover { background: #f8f9fc; }
    tbody td { padding: 12px 16px; color: #374151; }

    .role-badge { display: inline-block; padding: 2px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .role-admin { background: #ede9fe; color: #6d28d9; }
    .role-user  { background: #dbeafe; color: #1d4ed8; }

    .cost-badge { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 11px; font-weight: 500; background: #f3f4f6; color: #374151; }

    .actions { display: flex; gap: 8px; }

    .btn-sm {
      padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 500;
      cursor: pointer; border: 1.5px solid transparent; transition: all 0.2s;
    }

    .btn-edit   { background: #fff; border-color: #d1d5db; color: #374151; }
    .btn-edit:hover { background: #f3f4f6; border-color: #9ca3af; }
    .btn-reset  { background: #fff; border-color: #d1d5db; color: #374151; }
    .btn-reset:hover { background: #f3f4f6; border-color: #9ca3af; }
    .btn-delete { background: #fff; border-color: #fca5a5; color: #dc2626; }
    .btn-delete:hover { background: #fef2f2; }

    .empty-state { text-align: center; padding: 48px 0; color: #9ca3af; font-size: 14px; }

    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.5); z-index: 200;
      align-items: center; justify-content: center;
    }
    .modal-overlay.show { display: flex; }

    .modal {
      background: #fff; border-radius: 14px; padding: 32px;
      width: 100%; max-width: 480px; box-shadow: 0 24px 48px rgba(0,0,0,0.2);
    }

    .modal-title { font-size: 17px; font-weight: 700; margin-bottom: 20px; }
    .modal .form-group { margin-bottom: 14px; }

    .modal .form-group label {
      display: block; font-size: 12px; font-weight: 600; color: #6b7280; margin-bottom: 6px;
    }

    .modal .form-group input,
    .modal .form-group select {
      width: 100%; padding: 10px 14px; border: 1.5px solid #e5e7eb;
      border-radius: 8px; font-size: 14px; outline: none; background: #fafafa;
    }

    .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

    .modal-actions { display: flex; gap: 10px; margin-top: 24px; justify-content: flex-end; }

    .btn-cancel {
      padding: 10px 20px; background: #f3f4f6; border: none;
      border-radius: 8px; color: #374151; font-size: 14px; cursor: pointer;
    }

    .btn-save {
      padding: 10px 20px;
      background: linear-gradient(135deg, #4f7cff, #9b59b6);
      border: none; border-radius: 8px; color: #fff; font-size: 14px; font-weight: 600; cursor: pointer;
    }

    .btn-upload {
      padding: 10px 22px; height: 41px;
      background: linear-gradient(135deg, #059669, #10b981);
      border: none; border-radius: 8px; color: #fff;
      font-size: 14px; font-weight: 600; cursor: pointer; white-space: nowrap; transition: opacity 0.2s;
    }
    .btn-upload:hover { opacity: 0.85; }
    .btn-upload:disabled { opacity: 0.6; cursor: not-allowed; }

    .btn-template {
      padding: 8px 16px; background: #fff; border: 1.5px solid #e5e7eb;
      border-radius: 8px; color: #374151; font-size: 13px; font-weight: 500;
      text-decoration: none; display: inline-block; transition: background 0.2s;
    }
    .btn-template:hover { background: #f3f4f6; }

    .upload-area {
      border: 2px dashed #d1d5db; border-radius: 10px; padding: 20px 16px;
      text-align: center; cursor: pointer; transition: all 0.2s; background: #fafafa; margin-bottom: 14px;
    }
    .upload-area:hover, .upload-area.dragover { border-color: #4f7cff; background: #f0f4ff; }
    .upload-area-text { color: #6b7280; font-size: 14px; line-height: 1.7; }
    .upload-area-text strong { color: #4f7cff; }

    .upload-result { margin-top: 14px; font-size: 13px; }
    .result-success { color: #065f46; font-weight: 600; font-size: 14px; padding: 8px 0; }
    .result-fail-title { margin-top: 8px; color: #991b1b; font-weight: 600; }
    .result-fail-table { margin-top: 8px; width: 100%; border-collapse: collapse; font-size: 12px; }
    .result-fail-table th { background: #f8f9fc; padding: 6px 12px; text-align: left; border-bottom: 1px solid #e5e7eb; color: #6b7280; font-size: 11px; text-transform: uppercase; }
    .result-fail-table td { padding: 6px 12px; border-bottom: 1px solid #f3f4f6; }
  </style>
</head>
<body>

<header>
  <div class="header-left">
    인트라넷
    <span class="badge-admin">관리자</span>
  </div>
  <div class="header-right">
    <span class="user-info"><%= user.name %> (<%= user.empNo %>)</span>
    <a class="btn-logout" href="/logout">로그아웃</a>
  </div>
</header>

<div class="container">
  <div class="page-header">
    <div class="page-title">사용자 관리</div>
    <a class="btn-nav" href="/main">← 메인 메뉴</a>
    <a class="btn-nav" href="/prog_auth">프로그램 접근권한 관리 →</a>
  </div>

  <!-- 사용자 추가 -->
  <div class="card">
    <div class="card-title">신규 사용자 추가</div>
    <div class="form-grid">
      <div class="form-group">
        <label for="newName">이름</label>
        <input type="text" id="newName" placeholder="홍길동">
      </div>
      <div class="form-group">
        <label for="newEmpNo">사번</label>
        <input type="text" id="newEmpNo" placeholder="P00000">
      </div>
      <div class="form-group">
        <label for="newPhone">연락처</label>
        <input type="text" id="newPhone" placeholder="010-1234-5678">
      </div>
    </div>
    <div class="form-grid-2">
      <div class="form-group">
        <label for="newDept">부서</label>
        <input type="text" id="newDept" placeholder="운영1팀">
      </div>
      <div class="form-group">
        <label for="newPosition">직급</label>
        <input type="text" id="newPosition" placeholder="대리">
      </div>
      <div class="form-group">
        <label for="newCostType">비용구분</label>
        <select id="newCostType">
          <option value="운영">운영</option>
          <option value="판관">판관</option>
          <option value="자동차">자동차</option>
          <option value="운송">운송</option>
        </select>
      </div>
      <button class="btn-add" id="addBtn" onclick="addUser()">추가</button>
    </div>
    <div class="alert alert-success" id="addSuccess"></div>
    <div class="alert alert-error"   id="addError"></div>
  </div>

  <!-- 엑셀 일괄 업로드 -->
  <div class="card">
    <div class="card-title">엑셀 일괄 업로드</div>
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap;">
      <a class="btn-template" href="/api/users/template">양식 다운로드 ↓</a>
      <span style="font-size:13px;color:#6b7280;">이름·사번·연락처 필수 / 부서·직급·비용구분 선택 — 양식을 받아 작성 후 업로드하세요</span>
    </div>
    <div class="upload-area" id="uploadArea" onclick="triggerFileInput()">
      <input type="file" id="excelFile" accept=".xlsx,.xls" style="display:none" onchange="handleFileSelect(this)">
      <div class="upload-area-text" id="uploadAreaText">
        <strong>클릭하여 파일 선택</strong> 또는 여기로 파일을 끌어다 놓으세요<br>
        <span style="font-size:12px;">.xlsx, .xls 파일 지원</span>
      </div>
    </div>
    <div style="display:flex;gap:10px;align-items:center;">
      <button class="btn-upload" id="uploadBtn" onclick="uploadExcel()" disabled>업로드</button>
      <button class="btn-cancel" id="resetUploadBtn" onclick="resetUpload()" style="display:none;">취소</button>
    </div>
    <div id="uploadResult" class="upload-result"></div>
  </div>

  <!-- 사용자 목록 -->
  <div class="card">
    <div class="list-header">
      <div class="card-title" style="margin:0;padding:0;border:none;">사용자 목록</div>
      <div style="display:flex;align-items:center;gap:12px;">
        <span class="user-count" id="userCount"></span>
        <input class="search-input" type="text" placeholder="이름 또는 사번 검색"
               id="searchInput" oninput="filterUsers()">
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>이름</th><th>사번</th><th>연락처</th><th>부서</th><th>직급</th><th>비용구분</th><th>권한</th><th>관리</th>
          </tr>
        </thead>
        <tbody id="userTableBody"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- 수정 모달 -->
<div class="modal-overlay" id="editModal">
  <div class="modal">
    <div class="modal-title">사용자 정보 수정</div>
    <input type="hidden" id="editEmpNo">
    <div class="modal-grid">
      <div class="form-group">
        <label>이름</label>
        <input type="text" id="editName">
      </div>
      <div class="form-group">
        <label>연락처</label>
        <input type="text" id="editPhone">
      </div>
      <div class="form-group">
        <label>부서</label>
        <input type="text" id="editDept">
      </div>
      <div class="form-group">
        <label>직급</label>
        <input type="text" id="editPosition">
      </div>
    </div>
    <div class="form-group">
      <label>비용구분</label>
      <select id="editCostType">
        <option value="운영">운영</option>
        <option value="판관">판관</option>
        <option value="자동차">자동차</option>
        <option value="운송">운송</option>
      </select>
    </div>
    <div class="form-group">
      <label>권한</label>
      <select id="editRole">
        <option value="user">일반 사용자</option>
        <option value="admin">관리자</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal()">취소</button>
      <button class="btn-save"   onclick="saveEdit()">저장</button>
    </div>
  </div>
</div>

<script>
  var allUsers = [];

  async function loadUsers() {
    try {
      var res = await fetch('/api/users?_=' + Date.now());
      if (res.status === 401) { location.href = '/login'; return; }
      if (!res.ok) { document.getElementById('userTableBody').innerHTML = '<tr><td colspan="8"><div class="empty-state">사용자 목록을 불러오지 못했습니다. (서버 오류)</div></td></tr>'; return; }
      allUsers = await res.json();
      renderTable(allUsers);
    } catch(e) {
      document.getElementById('userTableBody').innerHTML = '<tr><td colspan="8"><div class="empty-state">사용자 목록을 불러오지 못했습니다.</div></td></tr>';
    }
  }

  function renderTable(users) {
    document.getElementById('userCount').textContent = '총 ' + users.length + '명';
    var tbody = document.getElementById('userTableBody');
    if (!users.length) {
      tbody.innerHTML = '<tr><td colspan="8"><div class="empty-state">등록된 사용자가 없습니다.</div></td></tr>';
      return;
    }
    tbody.innerHTML = users.map(function(u) {
      return '<tr>' +
        '<td><strong>' + esc(u.name) + '</strong></td>' +
        '<td>' + esc(u.empNo) + '</td>' +
        '<td>' + esc(u.phone) + '</td>' +
        '<td>' + esc(u.deptName || '-') + '</td>' +
        '<td>' + esc(u.position || '-') + '</td>' +
        '<td><span class="cost-badge">' + esc(u.costType || '운영') + '</span></td>' +
        '<td><span class="role-badge ' + (u.role === 'admin' ? 'role-admin' : 'role-user') + '">' + (u.role === 'admin' ? '관리자' : '일반') + '</span></td>' +
        '<td><div class="actions">' +
          '<button class="btn-sm btn-edit"  onclick="openEdit(\'' + esc(u.empNo) + '\')">수정</button>' +
          '<button class="btn-sm btn-reset" onclick="resetPw(\'' + esc(u.empNo) + '\',\'' + esc(u.name) + '\')">PW초기화</button>' +
          (u.empNo !== '0000' ? '<button class="btn-sm btn-delete" onclick="deleteUser(\'' + esc(u.empNo) + '\',\'' + esc(u.name) + '\')">삭제</button>' : '') +
        '</div></td>' +
      '</tr>';
    }).join('');
  }

  function filterUsers() {
    var q = document.getElementById('searchInput').value.trim().toLowerCase();
    renderTable(q ? allUsers.filter(function(u) { return u.name.toLowerCase().includes(q) || u.empNo.toLowerCase().includes(q); }) : allUsers);
  }

  async function addUser() {
    var name     = document.getElementById('newName').value.trim();
    var empNo    = document.getElementById('newEmpNo').value.trim();
    var phone    = document.getElementById('newPhone').value.trim();
    var deptName = document.getElementById('newDept').value.trim();
    var position = document.getElementById('newPosition').value.trim();
    var costType = document.getElementById('newCostType').value;
    var successEl = document.getElementById('addSuccess');
    var errorEl   = document.getElementById('addError');
    successEl.classList.remove('show');
    errorEl.classList.remove('show');

    if (!name || !empNo || !phone) {
      errorEl.textContent = '이름, 사번, 연락처를 모두 입력하세요.';
      errorEl.classList.add('show');
      return;
    }

    var btn = document.getElementById('addBtn');
    btn.disabled = true;

    var res = await fetch('/api/users', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, empNo, phone, deptName, position, costType })
    });
    var data = await res.json();
    btn.disabled = false;

    if (res.ok) {
      successEl.textContent = data.message;
      successEl.classList.add('show');
      document.getElementById('newName').value     = '';
      document.getElementById('newEmpNo').value    = '';
      document.getElementById('newPhone').value    = '';
      document.getElementById('newDept').value     = '';
      document.getElementById('newPosition').value = '';
      document.getElementById('newCostType').value = '운영';
      loadUsers();
    } else {
      errorEl.textContent = data.error;
      errorEl.classList.add('show');
    }
  }

  function openEdit(empNo) {
    var u = allUsers.find(function(u) { return u.empNo === empNo; });
    if (!u) return;
    document.getElementById('editEmpNo').value    = u.empNo;
    document.getElementById('editName').value     = u.name;
    document.getElementById('editPhone').value    = u.phone;
    document.getElementById('editDept').value     = u.deptName || '';
    document.getElementById('editPosition').value = u.position || '';
    document.getElementById('editCostType').value = u.costType || '운영';
    document.getElementById('editRole').value     = u.role;
    document.getElementById('editModal').classList.add('show');
  }

  function closeModal() {
    document.getElementById('editModal').classList.remove('show');
  }

  async function saveEdit() {
    var empNo    = document.getElementById('editEmpNo').value;
    var name     = document.getElementById('editName').value.trim();
    var phone    = document.getElementById('editPhone').value.trim();
    var deptName = document.getElementById('editDept').value.trim();
    var position = document.getElementById('editPosition').value.trim();
    var costType = document.getElementById('editCostType').value;
    var role     = document.getElementById('editRole').value;

    var res = await fetch('/api/users', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ empNo, name, phone, deptName, position, costType, role })
    });

    if (res.ok) { closeModal(); loadUsers(); }
    else { var d = await res.json(); alert(d.error); }
  }

  async function resetPw(empNo, name) {
    if (!confirm(name + ' 사용자의 비밀번호를 사번으로 초기화하시겠습니까?')) return;
    var res = await fetch('/api/reset_password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ empNo })
    });
    var data = await res.json();
    alert(data.message || data.error);
  }

  async function deleteUser(empNo, name) {
    if (!confirm(name + ' 사용자를 삭제하시겠습니까?\n이 작업은 되돌릴 수 없습니다.')) return;
    var res = await fetch('/api/users', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ empNo })
    });
    if (res.ok) loadUsers();
    else { var d = await res.json(); alert(d.error); }
  }

  function esc(str) {
    return String(str).replace(/[&<>"']/g, function(c) {
      return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
    });
  }

  function formatPhone(val) {
    var d = val.replace(/\D/g, '').slice(0, 11);
    if (d.slice(0, 2) === '02') {
      if (d.length < 3)  return d;
      if (d.length < 6)  return d.slice(0,2) + '-' + d.slice(2);
      if (d.length < 10) return d.slice(0,2) + '-' + d.slice(2,5) + '-' + d.slice(5);
      return d.slice(0,2) + '-' + d.slice(2,6) + '-' + d.slice(6,10);
    } else {
      if (d.length < 4)  return d;
      if (d.length < 7)  return d.slice(0,3) + '-' + d.slice(3);
      if (d.length < 11) return d.slice(0,3) + '-' + d.slice(3,6) + '-' + d.slice(6);
      return d.slice(0,3) + '-' + d.slice(3,7) + '-' + d.slice(7,11);
    }
  }

  function attachPhoneFormat(id) {
    document.getElementById(id).addEventListener('input', function() {
      var pos = this.selectionStart;
      var prev = this.value.length;
      this.value = formatPhone(this.value);
      var diff = this.value.length - prev;
      this.setSelectionRange(pos + diff, pos + diff);
    });
  }

  attachPhoneFormat('newPhone');
  attachPhoneFormat('editPhone');

  // ── 엑셀 일괄 업로드 ─────────────────────────────────────
  var _excelFile = null;

  function triggerFileInput() {
    document.getElementById('excelFile').click();
  }

  function handleFileSelect(input) {
    var file = input.files && input.files[0];
    if (!file) return;
    _excelFile = file;
    document.getElementById('uploadAreaText').innerHTML =
      '<strong>' + esc(file.name) + '</strong><br>' +
      '<span style="font-size:12px;color:#059669;">' + (file.size / 1024).toFixed(1) + ' KB — 업로드 준비 완료</span>';
    document.getElementById('uploadBtn').disabled = false;
    document.getElementById('resetUploadBtn').style.display = '';
  }

  function resetUpload() {
    _excelFile = null;
    document.getElementById('excelFile').value = '';
    document.getElementById('uploadAreaText').innerHTML =
      '<strong>클릭하여 파일 선택</strong> 또는 여기로 파일을 끌어다 놓으세요<br>' +
      '<span style="font-size:12px;">.xlsx, .xls 파일 지원</span>';
    document.getElementById('uploadBtn').disabled = true;
    document.getElementById('resetUploadBtn').style.display = 'none';
    document.getElementById('uploadResult').innerHTML = '';
  }

  async function uploadExcel() {
    if (!_excelFile) return;
    var btn = document.getElementById('uploadBtn');
    var resultEl = document.getElementById('uploadResult');
    btn.disabled = true;
    btn.textContent = '처리 중...';
    resultEl.innerHTML = '';

    var formData = new FormData();
    formData.append('file', _excelFile);

    try {
      var res = await fetch('/api/users/bulk', { method: 'POST', body: formData });
      var data = await res.json();

      if (!res.ok) {
        resultEl.innerHTML = '<div class="alert alert-error show">' + esc(data.error || '업로드 실패') + '</div>';
        btn.textContent = '업로드';
        btn.disabled = false;
        return;
      }

      var html = '<div class="result-success">✓ ' + data.success + '명 추가 완료</div>';
      if (data.failed && data.failed.length > 0) {
        html += '<div class="result-fail-title">✗ ' + data.failed.length + '건 실패</div>';
        html += '<table class="result-fail-table"><thead><tr><th>행</th><th>사번</th><th>이름</th><th>실패 사유</th></tr></thead><tbody>';
        data.failed.forEach(function(f) {
          html += '<tr><td>' + f.row + '</td><td>' + esc(f.empNo) + '</td><td>' + esc(f.name) + '</td><td>' + esc(f.reason) + '</td></tr>';
        });
        html += '</tbody></table>';
      }

      if (data.success > 0) loadUsers();
      resetUpload();
      resultEl.innerHTML = html;
    } catch (e) {
      resultEl.innerHTML = '<div class="alert alert-error show">업로드 중 오류가 발생했습니다.</div>';
      btn.textContent = '업로드';
      btn.disabled = false;
    }
  }

  (function() {
    var area = document.getElementById('uploadArea');
    area.addEventListener('dragover', function(e) { e.preventDefault(); this.classList.add('dragover'); });
    area.addEventListener('dragleave', function() { this.classList.remove('dragover'); });
    area.addEventListener('drop', function(e) {
      e.preventDefault();
      this.classList.remove('dragover');
      var file = e.dataTransfer.files[0];
      if (!file) return;
      if (!file.name.match(/\.(xlsx|xls)$/i)) { alert('.xlsx 또는 .xls 파일만 업로드 가능합니다.'); return; }
      _excelFile = file;
      document.getElementById('uploadAreaText').innerHTML =
        '<strong>' + esc(file.name) + '</strong><br>' +
        '<span style="font-size:12px;color:#059669;">' + (file.size / 1024).toFixed(1) + ' KB — 업로드 준비 완료</span>';
      document.getElementById('uploadBtn').disabled = false;
      document.getElementById('resetUploadBtn').style.display = '';
    });
  })();

  document.getElementById('editModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  ['newName','newEmpNo','newPhone'].forEach(function(id) {
    document.getElementById(id).addEventListener('keydown', function(e) {
      if (e.key === 'Enter') addUser();
    });
  });

  loadUsers();
</script>
</body>
</html>
