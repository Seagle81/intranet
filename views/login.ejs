<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>인트라넷 로그인</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #1a1f36 0%, #2d3561 50%, #1a1f36 100%);
      font-family: 'Segoe UI', 'Malgun Gothic', sans-serif;
    }

    .login-wrap { width: 100%; max-width: 420px; padding: 16px; }

    .card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 20px;
      padding: 48px 40px;
      backdrop-filter: blur(20px);
      box-shadow: 0 24px 48px rgba(0,0,0,0.4);
    }

    .logo-area { text-align: center; margin-bottom: 40px; }

    .logo-icon {
      width: 64px; height: 64px;
      background: linear-gradient(135deg, #4f7cff, #9b59b6);
      border-radius: 16px;
      display: inline-flex; align-items: center; justify-content: center;
      margin-bottom: 16px;
      box-shadow: 0 8px 24px rgba(79,124,255,0.4);
      font-size: 30px;
    }

    .logo-area h1 { color: #fff; font-size: 22px; font-weight: 700; }
    .logo-area p { color: rgba(255,255,255,0.45); font-size: 13px; margin-top: 4px; }

    .form-group { margin-bottom: 18px; }

    label {
      display: block;
      color: rgba(255,255,255,0.7);
      font-size: 13px; font-weight: 500;
      margin-bottom: 8px; letter-spacing: 0.3px;
    }

    input {
      width: 100%; padding: 13px 16px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 10px; color: #fff; font-size: 15px;
      transition: border-color 0.2s, background 0.2s; outline: none;
    }

    input::placeholder { color: rgba(255,255,255,0.25); }
    input:focus { border-color: #4f7cff; background: rgba(79,124,255,0.1); }

    .btn-login {
      width: 100%; padding: 14px; margin-top: 8px;
      background: linear-gradient(135deg, #4f7cff, #9b59b6);
      border: none; border-radius: 10px; color: #fff;
      font-size: 15px; font-weight: 600; cursor: pointer;
      transition: opacity 0.2s; letter-spacing: 0.5px;
    }

    .btn-login:hover { opacity: 0.88; }

    .error-msg {
      background: rgba(255,82,82,0.15);
      border: 1px solid rgba(255,82,82,0.4);
      border-radius: 8px; color: #ff8080;
      font-size: 13px; padding: 10px 14px;
      margin-top: 14px; text-align: center;
    }

    .footer-note {
      text-align: center; color: rgba(255,255,255,0.25);
      font-size: 12px; margin-top: 32px;
    }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="card">
      <div class="logo-area">
        <div class="logo-icon">&#127970;</div>
        <h1>인트라넷</h1>
        <p>사내 업무 시스템</p>
      </div>

      <form method="POST" action="/login">
        <div class="form-group">
          <label for="empNo">사번</label>
          <input type="text" id="empNo" name="empNo"
                 placeholder="사번을 입력하세요"
                 value="<%= empNo %>"
                 autocomplete="username" required>
        </div>
        <div class="form-group">
          <label for="password">비밀번호</label>
          <input type="password" id="password" name="password"
                 placeholder="비밀번호를 입력하세요"
                 autocomplete="current-password" required>
        </div>
        <button type="submit" class="btn-login">로그인</button>
        <% if (error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>
      </form>

      <div class="footer-note">계정 문의는 관리자에게 연락하세요</div>
    </div>
  </div>
</body>
</html>
