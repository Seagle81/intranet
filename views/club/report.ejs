<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>동호회 전체 보고서</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{min-height:100vh;background:#f0f2f5;font-family:'Segoe UI','Malgun Gothic',sans-serif;color:#1a1f36}
    header{background:linear-gradient(135deg,#1a1f36,#2d3561);color:#fff;padding:0 32px;height:60px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 12px rgba(0,0,0,.3);position:sticky;top:0;z-index:100}
    .hl{display:flex;align-items:center;gap:12px;font-size:16px;font-weight:600}
    .hr{display:flex;align-items:center;gap:16px}
    .ui{font-size:13px;color:rgba(255,255,255,.7)}
    .btn-lo{padding:7px 16px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:8px;color:#fff;font-size:13px;text-decoration:none}
    .sep{color:rgba(255,255,255,.4)}
    .container{max-width:1200px;margin:0 auto;padding:32px 16px}
    .ph{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px}
    .pt{font-size:22px;font-weight:700}
    .pa{display:flex;gap:8px}
    .btn-n{padding:8px 16px;background:#fff;border:1.5px solid #e5e7eb;border-radius:8px;color:#374151;font-size:13px;font-weight:500;text-decoration:none;cursor:pointer;white-space:nowrap}
    .btn-n:hover{background:#f3f4f6}
    .btn-print{padding:8px 18px;background:linear-gradient(135deg,#4f7cff,#9b59b6);border:none;border-radius:8px;color:#fff;font-size:13px;font-weight:600;cursor:pointer}
    .card{background:#fff;border-radius:14px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,.07);margin-bottom:20px}
    .card-title{font-size:15px;font-weight:700;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid #eef0f5;display:flex;align-items:center;justify-content:space-between}
    .ct-cost{display:inline-block;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:600}
    .ct-op{background:#dbeafe;color:#1d4ed8}
    .ct-pg{background:#ede9fe;color:#6d28d9}
    .ct-car{background:#dcfce7;color:#166534}
    .ct-tr{background:#fef9c3;color:#854d0e}
    .tw{overflow-x:auto}
    table{width:100%;border-collapse:collapse;font-size:13px}
    thead tr{background:#f8f9fc;border-bottom:2px solid #e5e7eb}
    thead th{padding:9px 12px;text-align:left;font-size:11px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap}
    tbody tr{border-bottom:1px solid #f3f4f6}
    tbody tr:hover{background:#f8f9fc}
    tbody td{padding:10px 12px}
    .num{text-align:right}
    tfoot tr{background:#f8f9fc;border-top:2px solid #e5e7eb;font-weight:700}
    tfoot td{padding:10px 12px}
    .paid-y{color:#166534;font-weight:600}
    .paid-n{color:#9ca3af}
    .empty{text-align:center;padding:40px 0;color:#9ca3af;font-size:14px}
    .summary-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
    @media(max-width:680px){.summary-grid{grid-template-columns:repeat(2,1fr)}}
    .summary-card{background:#fff;border-radius:12px;padding:18px;box-shadow:0 2px 8px rgba(0,0,0,.07);text-align:center}
    .s-label{font-size:12px;color:#6b7280;margin-bottom:6px}
    .s-val{font-size:22px;font-weight:800;color:#1a1f36}
    .s-sub{font-size:12px;color:#9ca3af;margin-top:2px}

    @media print {
      header,.ph .pa,button{display:none!important}
      body{background:#fff}
      .container{padding:0}
      .card{box-shadow:none;border:1px solid #e5e7eb;break-inside:avoid}
      .summary-grid{break-inside:avoid}
    }
  </style>
</head>
<body>
<header>
  <div class="hl">
    <a href="/main" style="color:inherit;text-decoration:none;">인트라넷</a>
    <span class="sep">›</span>
    <a href="/club" style="color:inherit;text-decoration:none;">동호회</a>
    <span class="sep">›</span>
    <span>전체 보고서</span>
  </div>
  <div class="hr">
    <span class="ui"><%= user.name %> (<%= user.empNo %>)</span>
    <a class="btn-lo" href="/logout">로그아웃</a>
  </div>
</header>

<div class="container">
  <div class="ph">
    <div class="pt">동호회 전체 보고서</div>
    <div class="pa">
      <a class="btn-n" href="/club">← 목록</a>
      <button class="btn-print" onclick="window.print()">인쇄</button>
    </div>
  </div>

  <!-- 요약 -->
  <div class="summary-grid" id="summaryGrid">
    <div class="summary-card"><div class="s-label">총 회원 수</div><div class="s-val" id="sTotalMembers">-</div></div>
    <div class="summary-card"><div class="s-label">월 활동비 합계</div><div class="s-val" id="sTotalFee">-</div><div class="s-sub">원/월</div></div>
    <div class="summary-card"><div class="s-label">미지급 지원금</div><div class="s-val" id="sTotalSupport">-</div><div class="s-sub">원 (일시)</div></div>
    <div class="summary-card"><div class="s-label">활성 동호회</div><div class="s-val" id="sTotalClubs">-</div></div>
  </div>

  <!-- cost_type별 테이블 -->
  <div id="reportContent"><div class="empty">로딩 중...</div></div>
</div>

<script>
var COST_LABELS = { '운영':'운영', '판관':'판관', '자동차':'자동차', '운송':'운송' };
var COST_CLASSES= { '운영':'ct-op', '판관':'ct-pg', '자동차':'ct-car', '운송':'ct-tr' };

function esc(s){return String(s||'').replace(/[&<>"']/g,function(c){return{'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
function fmtMoney(n){return Number(n||0).toLocaleString();}

async function loadReport() {
  var res = await fetch('/api/club/admin/report');
  var data = await res.json();
  if (!data.success) { document.getElementById('reportContent').innerHTML='<div class="empty">'+esc(data.message)+'</div>'; return; }
  var rows = data.data;

  // 요약
  var empSet = new Set(rows.map(function(r){return r.emp_no;}));
  var clubSet = new Set(rows.map(function(r){return r.club_id;}));
  var totalFee = rows.reduce(function(s,r){return s+Number(r.monthly_fee||0);},0);
  var totalSupport = rows.reduce(function(s,r){return s+Number(r.support_amt||0);},0);
  document.getElementById('sTotalMembers').textContent = empSet.size;
  document.getElementById('sTotalFee').textContent = fmtMoney(totalFee);
  document.getElementById('sTotalSupport').textContent = fmtMoney(totalSupport);
  document.getElementById('sTotalClubs').textContent = clubSet.size;

  // cost_type별 그룹
  var grouped = {};
  rows.forEach(function(r){
    var ct = r.cost_type || '운영';
    if (!grouped[ct]) grouped[ct] = [];
    grouped[ct].push(r);
  });

  var order = ['운영','판관','자동차','운송'];
  var html = '';
  order.forEach(function(ct) {
    if (!grouped[ct] || !grouped[ct].length) return;
    var list = grouped[ct];
    var subFee = list.reduce(function(s,r){return s+Number(r.monthly_fee||0);},0);
    var subSup = list.reduce(function(s,r){return s+Number(r.support_amt||0);},0);
    html += '<div class="card">';
    html += '<div class="card-title"><span><span class="ct-cost '+(COST_CLASSES[ct]||'')+'">'+COST_LABELS[ct]+'</span> &nbsp;'+list.length+'건</span><span style="font-size:13px;font-weight:400;color:#6b7280;">활동비 합계 '+fmtMoney(subFee)+'원/월 · 지원금 '+fmtMoney(subSup)+'원</span></div>';
    html += '<div class="tw"><table>';
    html += '<thead><tr><th>사번</th><th>성명</th><th>부서</th><th>직급</th><th>동호회명</th><th>가입일</th><th>지원금 대상월</th><th>지원금 지급</th><th class="num">월 활동비</th><th class="num">지원금</th></tr></thead>';
    html += '<tbody>';
    list.forEach(function(r) {
      html += '<tr>' +
        '<td>'+esc(r.emp_no)+'</td>' +
        '<td><strong>'+esc(r.name)+'</strong></td>' +
        '<td>'+esc(r.dept_name||'-')+'</td>' +
        '<td>'+esc(r.position||'-')+'</td>' +
        '<td>'+esc(r.club_name)+'</td>' +
        '<td>'+String(r.join_date||'').slice(0,10)+'</td>' +
        '<td>'+esc(r.support_month||'-')+'</td>' +
        '<td>'+(r.support_paid ? '<span class="paid-y">지급</span>' : '<span class="paid-n">미지급</span>')+'</td>' +
        '<td class="num">'+fmtMoney(r.monthly_fee)+'</td>' +
        '<td class="num">'+fmtMoney(r.support_amt)+'</td>' +
      '</tr>';
    });
    html += '</tbody><tfoot><tr><td colspan="8" style="text-align:right;color:#6b7280;">소계</td>' +
      '<td class="num">'+fmtMoney(subFee)+'</td>' +
      '<td class="num">'+fmtMoney(subSup)+'</td>' +
    '</tr></tfoot>';
    html += '</table></div></div>';
  });

  document.getElementById('reportContent').innerHTML = html || '<div class="empty">데이터가 없습니다.</div>';
}

loadReport();
</script>
</body>
</html>
