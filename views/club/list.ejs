<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>동호회</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{min-height:100vh;background:#f0f2f5;font-family:'Segoe UI','Malgun Gothic',sans-serif;color:#1a1f36}
    header{background:linear-gradient(135deg,#1a1f36,#2d3561);color:#fff;padding:0 32px;height:60px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 12px rgba(0,0,0,.3);position:sticky;top:0;z-index:100}
    .hl{display:flex;align-items:center;gap:12px;font-size:16px;font-weight:600}
    .hr{display:flex;align-items:center;gap:16px}
    .ui{font-size:13px;color:rgba(255,255,255,.7)}
    .btn-lo{padding:7px 16px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:8px;color:#fff;font-size:13px;text-decoration:none;transition:background .2s}
    .btn-lo:hover{background:rgba(255,255,255,.2)}
    .sep{color:rgba(255,255,255,.4)}
    .container{max-width:1100px;margin:0 auto;padding:32px 16px}
    .ph{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px}
    .pt{font-size:22px;font-weight:700}
    .pa{display:flex;gap:8px}
    .btn-n{padding:8px 16px;background:#fff;border:1.5px solid #e5e7eb;border-radius:8px;color:#374151;font-size:13px;font-weight:500;text-decoration:none;transition:background .2s;cursor:pointer;white-space:nowrap}
    .btn-n:hover{background:#f3f4f6}
    .btn-p{padding:8px 18px;background:linear-gradient(135deg,#4f7cff,#9b59b6);border:none;border-radius:8px;color:#fff;font-size:13px;font-weight:600;text-decoration:none;cursor:pointer;white-space:nowrap}
    .btn-p:hover{opacity:.85}
    .card{background:#fff;border-radius:14px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,.07);margin-bottom:24px}
    .ct{font-size:15px;font-weight:600;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid #eef0f5}
    .clubs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
    @media(max-width:860px){.clubs-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:540px){.clubs-grid{grid-template-columns:1fr}}
    .cc{background:#fff;border-radius:14px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,.07);cursor:pointer;transition:all .2s;text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:12px;border:2px solid transparent}
    .cc:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.12);border-color:#4f7cff}
    .cn{font-size:17px;font-weight:700}
    .cd{font-size:13px;color:#6b7280;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;flex:1}
    .cm{display:flex;gap:8px;flex-wrap:wrap}
    .cb{display:inline-flex;align-items:center;background:#f3f4f6;border-radius:6px;padding:3px 10px;font-size:12px;color:#374151}
    .empty{text-align:center;padding:60px 0;color:#9ca3af;font-size:15px;grid-column:1/-1}
    table{width:100%;border-collapse:collapse;font-size:14px}
    thead tr{background:#f8f9fc;border-bottom:2px solid #e5e7eb}
    thead th{padding:10px 14px;text-align:left;font-size:12px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.5px}
    tbody tr{border-bottom:1px solid #f3f4f6}
    tbody tr:hover{background:#f8f9fc}
    tbody td{padding:12px 14px}
    .sp{display:inline-block;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:600;background:#fef9c3;color:#854d0e}
    .acts{display:flex;gap:6px}
    .bs{padding:4px 12px;border-radius:6px;font-size:12px;font-weight:500;cursor:pointer;border:1.5px solid transparent;transition:all .2s}
    .ba{background:#fff;border-color:#4f7cff;color:#4f7cff}.ba:hover{background:#eff3ff}
    .br{background:#fff;border-color:#fca5a5;color:#dc2626}.br:hover{background:#fef2f2}
    .mo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;align-items:center;justify-content:center}
    .mo.show{display:flex}
    .mb{background:#fff;border-radius:14px;padding:28px;width:100%;max-width:400px;box-shadow:0 24px 48px rgba(0,0,0,.2)}
    .mt{font-size:16px;font-weight:700;margin-bottom:16px}
    .mo textarea{width:100%;padding:10px 14px;border:1.5px solid #e5e7eb;border-radius:8px;font-size:14px;resize:vertical;min-height:80px;outline:none}
    .mo textarea:focus{border-color:#4f7cff}
    .ma{display:flex;gap:10px;margin-top:16px;justify-content:flex-end}
    .bc{padding:9px 18px;background:#f3f4f6;border:none;border-radius:8px;color:#374151;font-size:14px;cursor:pointer}
    .bsv{padding:9px 18px;background:#dc2626;border:none;border-radius:8px;color:#fff;font-size:14px;font-weight:600;cursor:pointer}
    .tw{overflow-x:auto}
  </style>
</head>
<body>
<header>
  <div class="hl">
    <a href="/main" style="color:inherit;text-decoration:none;">인트라넷</a>
    <span class="sep">›</span>
    <span>동호회</span>
  </div>
  <div class="hr">
    <span class="ui"><%= user.name %> (<%= user.empNo %>)</span>
    <a class="btn-lo" href="/logout">로그아웃</a>
  </div>
</header>

<div class="container">
  <div class="ph">
    <div class="pt">동호회</div>
    <div class="pa">
      <% if (user.role === 'admin') { %>
        <a class="btn-n" href="/club/report">전체 보고서</a>
      <% } %>
      <a class="btn-p" href="/club/found">+ 개설 신청</a>
    </div>
  </div>

  <% if (user.role === 'admin') { %>
  <div class="card" id="foundSection" style="display:none">
    <div class="ct">개설 신청 대기</div>
    <div class="tw">
      <table>
        <thead><tr><th>동호회명</th><th>신청자</th><th>발기인</th><th>신청일</th><th>상태</th><th>관리</th></tr></thead>
        <tbody id="foundBody"></tbody>
      </table>
    </div>
  </div>
  <% } %>

  <div class="clubs-grid" id="clubsGrid">
    <div class="empty">로딩 중...</div>
  </div>
</div>

<div class="mo" id="rejectMo">
  <div class="mb">
    <div class="mt">반려 사유 입력</div>
    <textarea id="rejectReason" placeholder="반려 사유를 입력하세요."></textarea>
    <div class="ma">
      <button class="bc" onclick="closeReject()">취소</button>
      <button class="bsv" onclick="confirmReject()">반려 처리</button>
    </div>
  </div>
</div>

<script>
var isAdmin = <%- user.role === 'admin' ? 'true' : 'false' %>;
var rejectId = null;

function esc(s) {
  return String(s||'').replace(/[&<>"']/g,function(c){return{'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});
}

async function loadClubs() {
  var res = await fetch('/api/club/list');
  var data = await res.json();
  var grid = document.getElementById('clubsGrid');
  if (!data.success || !data.data.length) {
    grid.innerHTML = '<div class="empty">등록된 동호회가 없습니다.<br>개설 신청을 통해 첫 동호회를 만들어 보세요.</div>';
    return;
  }
  grid.innerHTML = data.data.map(function(c) {
    return '<a class="cc" href="/club/'+c.id+'">' +
      '<div class="cn">'+esc(c.club_name)+'</div>' +
      '<div class="cd">'+esc(c.description||'소개글이 없습니다.')+'</div>' +
      '<div class="cm">' +
        '<span class="cb">회원 '+c.member_count+'명</span>' +
        '<span class="cb">회장 '+esc(c.president_name||'-')+'</span>' +
        (c.found_date ? '<span class="cb">'+String(c.found_date).slice(0,10)+' 개설</span>' : '') +
      '</div>' +
    '</a>';
  }).join('');
}

async function loadFoundApply() {
  var res = await fetch('/api/club/found/pending');
  var data = await res.json();
  if (!data.success) return;
  var pending = (data.data||[]).filter(function(a){return a.status==='pending';});
  if (!pending.length) return;
  document.getElementById('foundSection').style.display = 'block';
  document.getElementById('foundBody').innerHTML = pending.map(function(a) {
    return '<tr>' +
      '<td><strong>'+esc(a.club_name)+'</strong></td>' +
      '<td>'+esc(a.applicant_name)+' ('+esc(a.applicant_emp_no)+')</td>' +
      '<td style="font-size:12px;color:#6b7280;max-width:160px;">'+esc(a.founder_names||'-')+'</td>' +
      '<td>'+String(a.reg_date).slice(0,10)+'</td>' +
      '<td><span class="sp">대기</span></td>' +
      '<td><div class="acts">' +
        '<button class="bs ba" onclick="approveFound('+a.id+')">승인</button>' +
        '<button class="bs br" onclick="openReject('+a.id+')">반려</button>' +
      '</div></td>' +
    '</tr>';
  }).join('');
}

async function approveFound(id) {
  if (!confirm('개설 신청을 승인하시겠습니까?')) return;
  var res = await fetch('/api/club/found/'+id+'/approve',{method:'POST'});
  var d = await res.json();
  alert(d.message);
  if (d.success) { loadClubs(); loadFoundApply(); }
}

function openReject(id) {
  rejectId = id;
  document.getElementById('rejectReason').value = '';
  document.getElementById('rejectMo').classList.add('show');
}
function closeReject() {
  document.getElementById('rejectMo').classList.remove('show');
  rejectId = null;
}
async function confirmReject() {
  var reason = document.getElementById('rejectReason').value.trim();
  if (!reason) { alert('반려 사유를 입력하세요.'); return; }
  var res = await fetch('/api/club/found/'+rejectId+'/reject',{
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({reason})
  });
  var d = await res.json();
  alert(d.message);
  if (d.success) { closeReject(); loadFoundApply(); }
}

document.getElementById('rejectMo').addEventListener('click',function(e){if(e.target===this)closeReject();});

loadClubs();
if (isAdmin) loadFoundApply();
</script>
</body>
</html>
